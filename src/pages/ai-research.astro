---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="AI Research">

  <!-- HERO -->
  <section class="hero">
    <h1>AI Research & Next-Gen Systems</h1>

    <p>
      This section focuses on Artificial Intelligence research including Machine Learning,
      Deep Learning, Generative AI, Large Language Models (LLMs), and AI Agents.
    </p>
  </section>

  <!-- COMING SOON BOX -->
  <section class="grid">

    <div class="card">
      <img
        src="https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1200&q=80"
        alt="AI Research"
      />

      <div class="meta">AI RESEARCH</div>
      <h3>Content Coming Soon</h3>
      <p>
        I am currently working on publishing real-world AI research,
        experiments with LLMs, AI Agents, and production-ready AI systems.
      </p>
    </div>

    <div class="card">
      <img
        src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?auto=format&fit=crop&w=1200&q=80"
        alt="AI Agents"
      />

      <div class="meta">AI AGENTS</div>
      <h3>Autonomous Systems</h3>
      <p>
        Research on autonomous AI agents, reasoning systems, and workflow automation will be added soon.
      </p>
    </div>

    <div class="card">
      <img
        src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1200&q=80"
        alt="Deep Learning"
      />

      <div class="meta">DEEP LEARNING</div>
      <h3>Neural Networks</h3>
      <p>
        Deep learning architectures, training methods, and real-world model deployment insights coming soon.
      </p>
    </div>

  </section>

</MainLayout>