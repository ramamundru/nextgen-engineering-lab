---
import MainLayout from "../layouts/MainLayout.astro";

const cards = [
  {
    title: "Microservices Architecture",
    desc: "Backend systems using scalable distributed architecture.",
    img: "https://images.unsplash.com/photo-1555949963-aa79dcee981c"
  },
  {
    title: "Frontend Engineering",
    desc: "Modern UI development with performance optimization.",
    img: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d"
  },
  {
    title: "DevOps & CI/CD",
    desc: "Docker, pipelines, and cloud deployment workflows.",
    img: "https://images.unsplash.com/photo-1558494949-ef010cbdcc31"
  },
  {
    title: "System Design",
    desc: "Scalable architectures and distributed systems.",
    img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71"
  },
  {
    title: "Machine Learning",
    desc: "Deep learning, neural networks, and AI models.",
    img: "https://images.unsplash.com/photo-1677442136019-21780ecad995"
  },
  {
    title: "AI Agents",
    desc: "LLMs, autonomous systems, and next-gen AI workflows.",
    img: "https://images.unsplash.com/photo-1682687220742-aba13b6e50ba"
  }
];
---

<MainLayout title="Home | NextGen Engineering Lab">

<!-- ✅ HERO (FIXED FULL CONTENT) -->
<section style="text-align:center; padding:60px 20px;">

  <h1 style="font-size:clamp(24px,4vw,40px); max-width:1100px; margin:auto;">
    Everything About Modern Software Engineering, AI Systems, and Next-Generation Technologies
  </h1>

  <p style="max-width:1000px; margin:20px auto; color:#64748b; line-height:1.9; font-size:15px;">
    I explore full-stack engineering including frontend development, backend engineering, system design, APIs, microservices, distributed systems, DevOps practices, CI/CD pipelines, Docker, and cloud infrastructure. I also work deeply with Artificial Intelligence including Machine Learning, Deep Learning, Generative AI, Large Language Models (LLMs), AI Agents, and autonomous intelligent systems.
  </p>

</section>

<!-- CARDS (UNCHANGED GRID - SAFE) -->
<section style="
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:22px;
  padding:40px;
  max-width:1200px;
  margin:auto;
">

  {cards.map(card => (
    <div style="
      background:white;
      border-radius:14px;
      overflow:hidden;
      box-shadow:0 6px 18px rgba(0,0,0,0.06);
      transition:0.2s ease;
    "
    onmouseover="this.style.transform='translateY(-6px)'"
    onmouseout="this.style.transform='translateY(0)'"
    >

      <img
        src={card.img + "?auto=format&fit=crop&w=1200&q=80"}
        style="width:100%; height:180px; object-fit:cover;"
      />

      <div style="padding:16px;">
        <h3 style="margin:0 0 8px 0; font-size:16px;">
          {card.title}
        </h3>

        <p style="color:#64748b; font-size:13px;">
          {card.desc}
        </p>
      </div>

    </div>
  ))}
</section>

</MainLayout>